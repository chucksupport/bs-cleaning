# Copy to .env.local for local development. None of these are required to run
# the site — the contact form gracefully no-ops (logs instead of sends) when
# RESEND_API_KEY is unset.

# Resend API key for sending contact-form emails.
# Get one at https://resend.com/api-keys
RESEND_API_KEY=

# Inbox that quote requests are delivered to.
CONTACT_FORM_TO=hello@bstrashbincleaning.com

# Optional: verified Resend sender. Defaults to onboarding@resend.dev (testing).
# Switch to an address on your verified domain once DNS is set up.
# CONTACT_FORM_FROM="B's Trash Bin Cleaning <quotes@bstrashbincleaning.com>"
